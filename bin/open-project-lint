#!/bin/sh

HELP_INFO ()
{
    echo "Usage: $0 path/to/project"
}

project="$1"
project="${project%/}"
if ! [ -d "$project" ]; then
    HELP_INFO >&2
    exit 1
fi


# Default to no issue.
exit_code=0


# Lint by rules
SUMMARY=
MESSAGE=
CWD=$(CDPATH='' cd -- "$(dirname -- "$0")" && pwd) || exit 1
for rule in "$CWD"/../lib/rule/*.sh; do
    . "$rule"
    lint "$project"

    if [ -n "$ERROR_SUMMARY" ]; then
        SUMMARY="${SUMMARY}${ERROR_SUMMARY}\n"
    fi

    if [ -n "$ERROR_MESSAGE" ]; then
        MESSAGE="${MESSAGE}${ERROR_MESSAGE}\n"
    fi

    if [ "$EXIT_STATUS" -ne 0 ]; then
        exit_code="$EXIT_STATUS"
    fi
done

if [ -n "$MESSAGE" ]; then
    printf "%b" "$MESSAGE"
fi


# Check directory structure
for directory in "$project"/*; do
    if ! [ -d "$directory" ]; then continue; fi

    case "$directory" in
    */bin|*/libexec) ;;
    */lib|*/src) ;;
    */share) ;;
    */examples) ;;
    */docs) ;;
    */tools|*/scripts) ;;
    */node_modules|*/local) ;;
    *)
        echo "Not a recommended directory: $directory" >&2
        exit_code=1
    esac
done


# Check for common VCS
no_vcs=1
for vcs_sub_directory in .git .hg .svn; do
    vcs_directory="$project/$vcs_sub_directory"

    if [ -d "$vcs_directory" ]; then
        no_vcs=0
        break
    fi
done

if [ "$no_vcs" -ne 0 ]; then
    echo "No version source control detected. Git is recommended" >&2
    exit_code=1
fi


# Fails on CI/CD
exit "$exit_code"
