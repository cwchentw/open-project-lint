#!/bin/sh

HELP_INFO ()
{
    echo "Usage: $0 path/to/project"
}

project="$1"
project="${project%/}"
if ! [ -d "$project" ]; then
    HELP_INFO >&2
    exit 1
fi

# Lint by rules
SUMMARY=
MESSAGE=
EXIT_STATUS=0
CWD=$(CDPATH='' cd -- "$(dirname -- "$0")" && pwd) || exit 1
for rule in "$CWD"/../lib/rule/*.sh; do
    . "$rule"
    lint "$project"

    if [ -n "$ERROR_SUMMARY" ]; then
        SUMMARY="${SUMMARY}${ERROR_SUMMARY}\n"
    fi

    if [ -n "$ERROR_MESSAGE" ]; then
        MESSAGE="${MESSAGE}${ERROR_MESSAGE}\n"
    fi
done

if [ -n "$MESSAGE" ]; then
    printf "%b" "$MESSAGE"
fi

# Fails on CI/CD
exit "$EXIT_STATUS"
